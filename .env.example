# Application Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials to source control.

# --- Database ---
# Default points at the compose `postgres` service.
# For local dev without Docker, update host/port/credentials accordingly.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/media_pipeline

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- File Storage ---
# Absolute path inside the container where uploaded images are stored.
# Mounted as a volume so both `api` and `worker` services can access files.
UPLOAD_DIR=/app/uploads

# --- Upload Limits ---
# Maximum allowed file size in bytes (default 10 MB)
MAX_FILE_SIZE_BYTES=10485760
